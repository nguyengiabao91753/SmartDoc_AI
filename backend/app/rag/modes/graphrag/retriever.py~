import logging
from typing import Dict, Any, Literal
from pydantic import BaseModel, Field

# Import cấu hình và LLM
from app.ai.llm import get_llm
from app.services.graph_rag_service import GraphRAGService

LOG = logging.getLogger(__name__)

# --- Định nghĩa Schema cho Router ---
class QueryRoute(BaseModel):
    strategy: Literal["LOCAL", "GLOBAL"] = Field(
        description="Chọn 'LOCAL' nếu hỏi chi tiết về người, vật, sự kiện cụ thể. Chọn 'GLOBAL' nếu hỏi bao quát, tóm tắt, đánh giá toàn cục."
    )

class GraphRAGRetriever:
    """
    Retriever thông minh: Phân loại câu hỏi trước khi truy xuất (Conditional Retrieval).
    """
    def __init__(self, graph_rag_service: GraphRAGService):
        self.service = graph_rag_service
        # ĐÃ SỬA: Chỉ dùng LLM chuẩn, không dùng with_structured_output để tránh lỗi NotImplementedError
        self.router_llm = get_llm(temperature=0)

    def _route_query(self, query: str) -> str:
        """Dùng Prompt để LLM quyết định xem nên dùng Local hay Global Search."""
        # ĐÃ SỬA: Sử dụng Prompt để ép kiểu kết quả thay vì dùng tính năng Schema của LangChain
        prompt = (
            "Bạn là một trợ lý định tuyến câu hỏi. Nhiệm vụ của bạn là chọn chiến lược tìm kiếm phù hợp.\n"
            "Chỉ được phép trả lời duy nhất một từ là 'LOCAL' hoặc 'GLOBAL'.\n"
            "- Chọn 'LOCAL' nếu câu hỏi yêu cầu chi tiết về thực thể, quan hệ hoặc sự kiện cụ thể.\n"
            "- Chọn 'GLOBAL' nếu câu hỏi yêu cầu tóm tắt, tổng quan hoặc ý chính của tài liệu.\n\n"
            f"Câu hỏi: {query}\n"
            "Chiến lược được chọn:"
        )
        try:
            # ĐÃ SỬA: Xử lý kết quả dạng chuỗi từ LLM
            response = self.router_llm.invoke(prompt)
            content = response.content.strip().upper()
            
            if "GLOBAL" in content:
                return "GLOBAL"
            return "LOCAL"
        except Exception as e:
            LOG.error(f"[GraphRAGRetriever] Lỗi Router, fallback về LOCAL: {e}")
            return "LOCAL" # Mặc định an toàn nếu lỗi

    def retrieve(self, query: str, top_k: int = 5) -> Dict[str, Any]:
        LOG.info(f"[GraphRAGRetriever] Đang xử lý câu hỏi: '{query}'")
        
        # 1. Định tuyến (Rẽ nhánh)
        strategy = self._route_query(query)
        LOG.info(f"[GraphRAGRetriever] 🧭 Chiến lược được chọn: {strategy}")
        
        # 2. Truy xuất có điều kiện
        if strategy == "LOCAL":
            context = self.service.search_local(query, top_k)
            context_type = "Chi tiết (Thực thể & Quan hệ)"
        else:
            context = self.service.search_global(query, top_k=3) # Global thường cần ít k hơn
            context_type = "Vĩ mô (Tóm tắt Cụm)"
            
        # 3. Trả về đúng 1 ngữ cảnh duy nhất
        return {
            "query": query,
            "strategy": strategy,
            "context_type": context_type,
            "context": context if context else "Không tìm thấy thông tin phù hợp trong cơ sở dữ liệu."
        }
